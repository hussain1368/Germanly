<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GermanToolbox.UserProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0.0" Color="#FAFAF8" />
            <GradientStop Offset="0.5" Color="#EEF4F8" />
            <GradientStop Offset="1.0" Color="#F3F7EF" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="20,18,20,28" Spacing="14">
            <Grid ColumnDefinitions="40,*" ColumnSpacing="10">
                <Border
                    BackgroundColor="#FFFFFF"
                    HeightRequest="40"
                    Stroke="#E8E8E4"
                    StrokeThickness="1"
                    WidthRequest="40">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Path
                        Aspect="Uniform"
                        Data="M 19 8 L 11 16 L 19 24"
                        Fill="Transparent"
                        HeightRequest="22"
                        HorizontalOptions="Center"
                        SemanticProperties.Description="Back"
                        Stroke="#171717"
                        StrokeLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeThickness="2.4"
                        VerticalOptions="Center"
                        WidthRequest="22" />
                </Border>

                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="0"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="22"
                        Text="Profil"
                        TextColor="#171717" />
                    <Label
                        FontSize="11"
                        Text="Your account at a glance"
                        TextColor="#777777" />
                </VerticalStackLayout>
            </Grid>

            <Border Padding="22" StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#30000000" Offset="0,14" Opacity="0.26" Radius="24" />
                </Border.Shadow>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0.0" Color="#171717" />
                        <GradientStop Offset="0.58" Color="#243047" />
                        <GradientStop Offset="1.0" Color="#1E4770" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="12">
                    <Grid
                        HeightRequest="116"
                        HorizontalOptions="Center"
                        WidthRequest="116">
                        <Ellipse
                            Fill="#FFFFFF"
                            Stroke="#DCE8F6"
                            StrokeThickness="2" />
                        <Image
                            Aspect="AspectFill"
                            HeightRequest="108"
                            HorizontalOptions="Center"
                            Source="profile_avatar.png"
                            VerticalOptions="Center"
                            WidthRequest="108">
                            <Image.Clip>
                                <EllipseGeometry
                                    Center="54,54"
                                    RadiusX="54"
                                    RadiusY="54" />
                            </Image.Clip>
                        </Image>
                    </Grid>

                    <VerticalStackLayout Spacing="3">
                        <Label
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            FontSize="29"
                            HorizontalTextAlignment="Center"
                            Text="Alex Morgan"
                            TextColor="#FFFFFF" />
                        <Label
                            FontSize="13"
                            HorizontalTextAlignment="Center"
                            Text="alex.morgan@example.com"
                            TextColor="#DCE8F6" />
                    </VerticalStackLayout>

                    <Border
                        Padding="10,6"
                        BackgroundColor="#18FFFFFF"
                        HorizontalOptions="Center"
                        Stroke="#28FFFFFF"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Label
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            FontSize="11"
                            Text="GERMAN LEARNER"
                            TextColor="#8FD6FF" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Label
                Margin="2,4,0,0"
                FontAttributes="Bold"
                FontFamily="OpenSansSemibold"
                FontSize="13"
                Text="KONTODATEN"
                TextColor="#667085" />

            <Border
                Padding="17"
                BackgroundColor="#FFFFFF"
                Stroke="#DDE8F5"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="48,*" ColumnSpacing="13">
                    <Border
                        BackgroundColor="#EAF1FF"
                        HeightRequest="48"
                        Stroke="#CFE0FF"
                        StrokeThickness="1"
                        WidthRequest="48">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Label
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            FontSize="20"
                            HorizontalTextAlignment="Center"
                            Text="@"
                            TextColor="#2563EB"
                            VerticalTextAlignment="Center" />
                    </Border>
                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="2"
                        VerticalOptions="Center">
                        <Label FontSize="11" Text="E-MAIL" TextColor="#777777" />
                        <Label
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            FontSize="15"
                            LineBreakMode="TailTruncation"
                            Text="alex.morgan@example.com"
                            TextColor="#171717" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border
                    Padding="16"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDE8F5"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Border
                            BackgroundColor="#F3F7EF"
                            HeightRequest="42"
                            HorizontalOptions="Start"
                            Stroke="#DCEBDD"
                            StrokeThickness="1"
                            WidthRequest="42">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label
                                FontSize="20"
                                HorizontalTextAlignment="Center"
                                Text="◷"
                                TextColor="#2E7D32"
                                VerticalTextAlignment="Center" />
                        </Border>
                        <Label FontSize="11" Text="GEBURTSDATUM" TextColor="#777777" />
                        <Label
                            x:Name="BirthDateLabel"
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            FontSize="17"
                            Text="16.05.1997"
                            TextColor="#171717" />
                    </VerticalStackLayout>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="16"
                    BackgroundColor="#FFFFFF"
                    Stroke="#DDE8F5"
                    StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="6">
                        <Border
                            BackgroundColor="#FFF4DD"
                            HeightRequest="42"
                            HorizontalOptions="Start"
                            Stroke="#F3DDAA"
                            StrokeThickness="1"
                            WidthRequest="42">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Label
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="18"
                                HorizontalTextAlignment="Center"
                                Text="#"
                                TextColor="#A66800"
                                VerticalTextAlignment="Center" />
                        </Border>
                        <Label FontSize="11" Text="ALTER" TextColor="#777777" />
                        <Label
                            x:Name="AgeLabel"
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            FontSize="17"
                            Text="29 Jahre"
                            TextColor="#171717" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Border
                Padding="16"
                BackgroundColor="#F7FAFF"
                Stroke="#DDE8F5"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label
                    FontSize="12"
                    HorizontalTextAlignment="Center"
                    LineBreakMode="WordWrap"
                    Text="Profile data is sample content for the design preview. Editing and account synchronization will be added later."
                    TextColor="#667085" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
