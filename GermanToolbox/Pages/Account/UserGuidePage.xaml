<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GermanToolbox.UserGuidePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GermanToolbox"
    x:DataType="local:UserGuidePage"
    BackgroundColor="#FAFAF8"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">
        <CarouselView
            x:Name="GuideCarousel"
            Grid.Row="0"
            HorizontalScrollBarVisibility="Never"
            IndicatorView="{x:Reference GuideIndicator}"
            ItemsSource="{Binding Slides}"
            Loop="False"
            PositionChanged="OnPositionChanged">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout
                    Orientation="Horizontal"
                    SnapPointsAlignment="Center"
                    SnapPointsType="MandatorySingle" />
            </CarouselView.ItemsLayout>
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="local:UserGuideSlide">
                    <Grid Padding="20,0,20,14" RowDefinitions="*,Auto" RowSpacing="12">
                        <Image
                            Aspect="AspectFit"
                            HorizontalOptions="Fill"
                            Source="{Binding Image}"
                            VerticalOptions="Fill" />
                        <Label
                            Grid.Row="1"
                            FontSize="15"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap"
                            MaximumWidthRequest="470"
                            Text="{Binding Description}"
                            TextColor="#666666" />
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <VerticalStackLayout
            Grid.Row="1"
            Padding="20,8,20,22"
            Spacing="16">
            <IndicatorView
                x:Name="GuideIndicator"
                HorizontalOptions="Center"
                IndicatorColor="#CFD6E2"
                IndicatorSize="8"
                MaximumVisible="4"
                SelectedIndicatorColor="#2563EB" />

            <VerticalStackLayout Spacing="10">
                <Button
                    x:Name="NextButton"
                    BackgroundColor="#2563EB"
                    Clicked="OnNextClicked"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    HeightRequest="50"
                    Text="Weiter"
                    TextColor="#FFFFFF" />
                <Button
                    BackgroundColor="#FFFFFF"
                    BorderColor="#D8DEE8"
                    BorderWidth="1"
                    Clicked="OnSkipClicked"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    HeightRequest="50"
                    Text="Überspringen"
                    TextColor="#555555" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
