<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GermanToolbox.UserGuidePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GermanToolbox"
    x:DataType="local:UserGuidePage"
    BackgroundColor="#FAFAF8"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <Label
            Grid.Row="0"
            Margin="0,14,20,0"
            FontSize="14"
            HorizontalOptions="End"
            SemanticProperties.Description="Skip user guide"
            Text="Skip"
            TextColor="#3874FF">
            <Label.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSkipClicked" />
            </Label.GestureRecognizers>
        </Label>

        <CarouselView
            x:Name="GuideCarousel"
            Grid.Row="1"
            HorizontalScrollBarVisibility="Never"
            IndicatorView="{x:Reference GuideIndicator}"
            ItemsSource="{Binding Slides}"
            Loop="False"
            PositionChanged="OnPositionChanged">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout
                    Orientation="Horizontal"
                    SnapPointsAlignment="Center"
                    SnapPointsType="MandatorySingle" />
            </CarouselView.ItemsLayout>
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="local:UserGuideSlide">
                    <Grid
                        Padding="20,0,20,14"
                        RowDefinitions="*,Auto"
                        RowSpacing="12">
                        <Image
                            Aspect="AspectFit"
                            HorizontalOptions="Fill"
                            Source="{Binding Image}"
                            VerticalOptions="Fill" />
                        <Label
                            Grid.Row="1"
                            FontSize="15"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="WordWrap"
                            MaximumWidthRequest="470"
                            Text="{Binding Description}"
                            TextColor="#666666" />
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <VerticalStackLayout
            Grid.Row="2"
            Padding="20,8,20,22"
            Spacing="16">
            <IndicatorView
                x:Name="GuideIndicator"
                HorizontalOptions="Center"
                IndicatorColor="#CFD6E2"
                IndicatorSize="8"
                MaximumVisible="4"
                SelectedIndicatorColor="#2563EB" />

            <Button
                x:Name="NextButton"
                BackgroundColor="White"
                BorderColor="#2563EB"
                BorderWidth="2"
                Clicked="OnNextClicked"
                CornerRadius="8"
                FontAttributes="Bold"
                FontFamily="OpenSansSemibold"
                HeightRequest="50"
                Text="Next"
                TextColor="#2563EB" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
