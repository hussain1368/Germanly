<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GermanToolbox.PluralsStartPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GermanToolbox"
    Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0.0" Color="#FAFAF8" />
            <GradientStop Offset="0.52" Color="#F5F1FA" />
            <GradientStop Offset="1.0" Color="#F2EEF7" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20,18" Spacing="14">
                <Grid ColumnDefinitions="40,*" ColumnSpacing="10">
                    <Border
                        BackgroundColor="#FFFFFF"
                        HeightRequest="40"
                        Stroke="#E8E8E4"
                        WidthRequest="40">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                        <Path
                            Aspect="Uniform"
                            Data="M 19 8 L 11 16 L 19 24"
                            Fill="Transparent"
                            HeightRequest="22"
                            HorizontalOptions="Center"
                            SemanticProperties.Description="Back"
                            Stroke="#171717"
                            StrokeLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeThickness="2.4"
                            VerticalOptions="Center"
                            WidthRequest="22" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="0" VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            FontSize="22"
                            Text="Plural"
                            TextColor="#171717" />
                            <Grid
                                ColumnDefinitions="16,16,16"
                                ColumnSpacing="5"
                                Margin="0,5,0,0"
                                VerticalOptions="Center">
                                <BoxView BackgroundColor="#6D4AA2" CornerRadius="2" HeightRequest="4" />
                                <BoxView Grid.Column="1" BackgroundColor="#A05A9D" CornerRadius="2" HeightRequest="4" />
                                <BoxView Grid.Column="2" BackgroundColor="#5977B8" CornerRadius="2" HeightRequest="4" />
                            </Grid>
                    </VerticalStackLayout>
                </Grid>

                <Border Padding="16" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#30000000" Offset="0,14" Opacity="0.26" Radius="24" />
                    </Border.Shadow>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0.0" Color="#21152F" />
                            <GradientStop Offset="0.58" Color="#3B2853" />
                            <GradientStop Offset="1.0" Color="#160E21" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <VerticalStackLayout Spacing="11">

                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="30"
                                Text="das Wort → die Wörter"
                                TextColor="#FFFFFF" />
                            <Label
                                FontSize="13"
                                Text="Choose how you want to practise German noun plurals."
                                TextColor="#DED2ED" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <Border Padding="9" BackgroundColor="#18FFFFFF" Stroke="#22FFFFFF">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="0">
                                    <Label FontSize="10" Text="Gelernt" TextColor="#D8CAE9" />
                                    <Label
                                        x:Name="LearnedCountLabel"
                                        FontAttributes="Bold"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="18"
                                        Text="0"
                                        TextColor="#FFFFFF" />
                                </VerticalStackLayout>
                            </Border>
                            <Border
                                Grid.Column="1"
                                Padding="9"
                                BackgroundColor="#18FFFFFF"
                                Stroke="#22FFFFFF">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="0">
                                    <Label FontSize="10" Text="Fällig" TextColor="#D8CAE9" />
                                    <Label
                                        x:Name="DueCountLabel"
                                        FontAttributes="Bold"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="18"
                                        Text="0"
                                        TextColor="#FFFFFF" />
                                </VerticalStackLayout>
                            </Border>
                            <Border
                                Grid.Column="2"
                                Padding="9"
                                BackgroundColor="#18FFFFFF"
                                Stroke="#22FFFFFF">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="0">
                                    <Label FontSize="10" Text="Fehler" TextColor="#D8CAE9" />
                                    <Label
                                        x:Name="MistakeCountLabel"
                                        FontAttributes="Bold"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="18"
                                        Text="0"
                                        TextColor="#FFFFFF" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="15"
                        Text="Niveau"
                        TextColor="#171717" />

                    <Grid
                        ColumnDefinitions="*,*,*,*,*"
                        ColumnSpacing="6">
                        <Border
                            x:Name="A1Level"
                            Padding="0"
                            BackgroundColor="#F1ECFA"
                            Stroke="#6D4AA2"
                            StrokeThickness="2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnA1Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="A1LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#E3D8F5"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="A1LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="A1"
                                    TextColor="#6D4AA2" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="A2Level"
                            Grid.Column="1"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="#E4E4DE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnA2Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="A2LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#E3D8F5"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="A2LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="A2"
                                    TextColor="#171717" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="B1Level"
                            Grid.Column="2"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="#E4E4DE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnB1Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="B1LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#E3D8F5"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="B1LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="B1"
                                    TextColor="#171717" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="B2Level"
                            Grid.Column="3"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="#E4E4DE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnB2Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="B2LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#E3D8F5"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="B2LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="B2"
                                    TextColor="#171717" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="C1Level"
                            Grid.Column="4"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="#E4E4DE">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnC1Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="C1LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#E3D8F5"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="C1LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="C1"
                                    TextColor="#171717" />
                            </Grid>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="15"
                        Text="Testmethode"
                        TextColor="#171717" />

                    <Border
                        x:Name="MultipleChoiceOption"
                        Padding="12,10"
                        BackgroundColor="#F1ECFA"
                        Stroke="#6D4AA2"
                        StrokeThickness="2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnMultipleChoiceTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="2">
                            <Label
                                x:Name="MultipleChoiceTitle"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Text="Antwort auswählen"
                                TextColor="#6D4AA2" />
                            <Label
                                x:Name="MultipleChoiceSubtitle"
                                FontSize="11"
                                Text="Pick any correct plural from realistic alternatives"
                                TextColor="#6D4AA2" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        x:Name="TypingOption"
                        Padding="12,10"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTypingTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="2">
                            <Label
                                x:Name="TypingTitle"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Text="Antwort eingeben"
                                TextColor="#171717" />
                            <Label
                                x:Name="TypingSubtitle"
                                FontSize="11"
                                Text="Recall and enter an accepted plural yourself"
                                TextColor="#777777" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        x:Name="SelfAssessmentOption"
                        Padding="12,10"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSelfAssessmentTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="2">
                            <Label
                                x:Name="SelfAssessmentTitle"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Text="Aufdecken und entscheiden"
                                TextColor="#171717" />
                            <Label
                                x:Name="SelfAssessmentSubtitle"
                                FontSize="11"
                                Text="Reveal the plural, then mark your own answer"
                                TextColor="#777777" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Button
                        BackgroundColor="#6D4AA2"
                        Clicked="OnStartTestClicked"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        HeightRequest="48"
                        Text="Test starten"
                        TextColor="#FFFFFF" />
                    <Button
                        x:Name="ReviewMistakesButton"
                        BackgroundColor="#FFFFFF"
                        BorderColor="#E4DDF2"
                        BorderWidth="1"
                        Clicked="OnReviewMistakesClicked"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        HeightRequest="48"
                        Text="Fehler wiederholen"
                        TextColor="#171717" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavigationView
            Grid.Row="1"
            SelectedTab="Practice"
            TabSelected="OnBottomTabSelected" />
    </Grid>
</ContentPage>
