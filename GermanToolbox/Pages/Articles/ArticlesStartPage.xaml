<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GermanToolbox.ArticlesStartPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GermanToolbox"
    Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0.0" Color="#FAFAF8" />
            <GradientStop Offset="0.52" Color="#F1F6F3" />
            <GradientStop Offset="1.0" Color="#F8EEE9" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="*,Auto">
    <ScrollView>
        <VerticalStackLayout
            Padding="20,18"
            Spacing="12">
            <Grid
                ColumnDefinitions="40,*"
                ColumnSpacing="10">
                <Border
                    BackgroundColor="#FFFFFF"
                    HeightRequest="40"
                    Stroke="#E8E8E4"
                    StrokeThickness="1"
                    WidthRequest="40">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                    <Path
                        Aspect="Uniform"
                        Data="M 19 8 L 11 16 L 19 24"
                        Fill="Transparent"
                        HeightRequest="22"
                        HorizontalOptions="Center"
                        SemanticProperties.Description="Back"
                        Stroke="#171717"
                        StrokeLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeThickness="2.4"
                        VerticalOptions="Center"
                        WidthRequest="22" />
                </Border>

                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="0"
                    VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="22"
                        Text="Artikel"
                        TextColor="#171717" />
       
                        <Grid
                            Margin="0,5,0,0"
                            ColumnDefinitions="16,16,16"
                            ColumnSpacing="5"
                            VerticalOptions="Center">
                            <BoxView
                                BackgroundColor="#2563EB"
                                CornerRadius="2"
                                HeightRequest="4" />
                            <BoxView
                                Grid.Column="1"
                                BackgroundColor="#D43D35"
                                CornerRadius="2"
                                HeightRequest="4" />
                            <BoxView
                                Grid.Column="2"
                                BackgroundColor="#2E7D32"
                                CornerRadius="2"
                                HeightRequest="4" />
                        </Grid>
                </VerticalStackLayout>
            </Grid>

            <Border
                Padding="16"
                StrokeThickness="0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow
                        Brush="#30000000"
                        Offset="0,14"
                        Opacity="0.26"
                        Radius="24" />
                </Border.Shadow>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Offset="0.0" Color="#202020" />
                        <GradientStop Offset="0.64" Color="#2B2F30" />
                        <GradientStop Offset="1.0" Color="#171717" />
                    </LinearGradientBrush>
                </Border.Background>

                <VerticalStackLayout Spacing="10">

                    <VerticalStackLayout Spacing="4">
                        <Label
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            FontSize="30"
                            Text="der, die, das"
                            TextColor="#FFFFFF" />
                        <Label
                            FontSize="13"
                            Text="Choose your article set and grammatical case before starting."
                            TextColor="#D8D8D8" />
                    </VerticalStackLayout>

                    <Grid
                        ColumnDefinitions="*,*,*"
                        ColumnSpacing="8">
                        <Border
                            Padding="9"
                            BackgroundColor="#18FFFFFF"
                            Stroke="#22FFFFFF"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="0">
                                <Label
                                    FontSize="10"
                                    Text="Gelernt"
                                    TextColor="#BDBDBD" />
                                <Label
                                    x:Name="ArticleLearnedCountLabel"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="18"
                                    Text="0"
                                    TextColor="#FFFFFF" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="9"
                            BackgroundColor="#18FFFFFF"
                            Stroke="#22FFFFFF"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="0">
                                <Label
                                    FontSize="10"
                                    Text="Fällig"
                                    TextColor="#BDBDBD" />
                                <Label
                                    x:Name="ArticleDueCountLabel"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="18"
                                    Text="0"
                                    TextColor="#FFFFFF" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="9"
                            BackgroundColor="#18FFFFFF"
                            Stroke="#22FFFFFF"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="0">
                                <Label
                                    FontSize="10"
                                    Text="Fehler"
                                    TextColor="#BDBDBD" />
                                <Label
                                    x:Name="ArticleMistakeCountLabel"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="18"
                                    Text="12"
                                    TextColor="#FFFFFF" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="6">
                <Label
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    FontSize="15"
                    Text="Niveau"
                    TextColor="#171717" />

                <Grid
                    ColumnDefinitions="*,*,*,*,*"
                    ColumnSpacing="6">
                    <Border
                        x:Name="A1Level"
                        Padding="0"
                        BackgroundColor="#EAF1FF"
                        Stroke="#2563EB"
                        StrokeThickness="2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnA1Tapped" />
                        </Border.GestureRecognizers>
                        <Grid InputTransparent="True">
                            <AbsoluteLayout
                                x:Name="A1LevelProgress"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill">
                                <BoxView
                                    AbsoluteLayout.LayoutBounds="0,0,0,1"
                                    AbsoluteLayout.LayoutFlags="All"
                                    BackgroundColor="#D7E6FF"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill" />
                            </AbsoluteLayout>
                            <Label
                                x:Name="A1LevelTitle"
                                Margin="6,8"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                HorizontalTextAlignment="Center"
                                Text="A1"
                                TextColor="#2563EB" />
                        </Grid>
                    </Border>

                    <Border
                        x:Name="A2Level"
                        Grid.Column="1"
                        Padding="0"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnA2Tapped" />
                        </Border.GestureRecognizers>
                        <Grid InputTransparent="True">
                            <AbsoluteLayout
                                x:Name="A2LevelProgress"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill">
                                <BoxView
                                    AbsoluteLayout.LayoutBounds="0,0,0,1"
                                    AbsoluteLayout.LayoutFlags="All"
                                    BackgroundColor="#D7E6FF"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill" />
                            </AbsoluteLayout>
                            <Label
                                x:Name="A2LevelTitle"
                                Margin="6,8"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                HorizontalTextAlignment="Center"
                                Text="A2"
                                TextColor="#171717" />
                        </Grid>
                    </Border>

                    <Border
                        x:Name="B1Level"
                        Grid.Column="2"
                        Padding="0"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnB1Tapped" />
                        </Border.GestureRecognizers>
                        <Grid InputTransparent="True">
                            <AbsoluteLayout
                                x:Name="B1LevelProgress"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill">
                                <BoxView
                                    AbsoluteLayout.LayoutBounds="0,0,0,1"
                                    AbsoluteLayout.LayoutFlags="All"
                                    BackgroundColor="#D7E6FF"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill" />
                            </AbsoluteLayout>
                            <Label
                                x:Name="B1LevelTitle"
                                Margin="6,8"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                HorizontalTextAlignment="Center"
                                Text="B1"
                                TextColor="#171717" />
                        </Grid>
                    </Border>

                    <Border
                        x:Name="B2Level"
                        Grid.Column="3"
                        Padding="0"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnB2Tapped" />
                        </Border.GestureRecognizers>
                        <Grid InputTransparent="True">
                            <AbsoluteLayout
                                x:Name="B2LevelProgress"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill">
                                <BoxView
                                    AbsoluteLayout.LayoutBounds="0,0,0,1"
                                    AbsoluteLayout.LayoutFlags="All"
                                    BackgroundColor="#D7E6FF"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill" />
                            </AbsoluteLayout>
                            <Label
                                x:Name="B2LevelTitle"
                                Margin="6,8"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                HorizontalTextAlignment="Center"
                                Text="B2"
                                TextColor="#171717" />
                        </Grid>
                    </Border>

                    <Border
                        x:Name="C1Level"
                        Grid.Column="4"
                        Padding="0"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnC1Tapped" />
                        </Border.GestureRecognizers>
                        <Grid InputTransparent="True">
                            <AbsoluteLayout
                                x:Name="C1LevelProgress"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill">
                                <BoxView
                                    AbsoluteLayout.LayoutBounds="0,0,0,1"
                                    AbsoluteLayout.LayoutFlags="All"
                                    BackgroundColor="#D7E6FF"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill" />
                            </AbsoluteLayout>
                            <Label
                                x:Name="C1LevelTitle"
                                Margin="6,8"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                HorizontalTextAlignment="Center"
                                Text="C1"
                                TextColor="#171717" />
                        </Grid>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    FontSize="15"
                    Text="Kasus"
                    TextColor="#171717" />

                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="8"
                    RowDefinitions="Auto,Auto"
                    RowSpacing="8">
                    <Border
                        x:Name="NominativeCase"
                        Padding="10,8"
                        BackgroundColor="#EAF1FF"
                        Stroke="#2563EB"
                        StrokeThickness="2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNominativeTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="2">
                            <Label
                                x:Name="NominativeCaseTitle"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                Text="Nominativ"
                                TextColor="#2563EB" />
                            <Label
                                x:Name="NominativeCaseSubtitle"
                                FontSize="10"
                                Text="der, die, das"
                                TextColor="#2563EB" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        x:Name="AccusativeCase"
                        Grid.Column="1"
                        Padding="10,8"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAccusativeTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="2">
                            <Label
                                x:Name="AccusativeCaseTitle"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                Text="Akkusativ"
                                TextColor="#171717" />
                            <Label
                                x:Name="AccusativeCaseSubtitle"
                                FontSize="10"
                                Text="den, die, das"
                                TextColor="#777777" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        x:Name="DativeCase"
                        Grid.Row="1"
                        Padding="10,8"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDativeTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="2">
                            <Label
                                x:Name="DativeCaseTitle"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                Text="Dativ"
                                TextColor="#171717" />
                            <Label
                                x:Name="DativeCaseSubtitle"
                                FontSize="10"
                                Text="dem, der, dem"
                                TextColor="#777777" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        x:Name="GenitiveCase"
                        Grid.Row="1"
                        Grid.Column="1"
                        Padding="10,8"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnGenitiveTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="2">
                            <Label
                                x:Name="GenitiveCaseTitle"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="13"
                                Text="Genitiv"
                                TextColor="#171717" />
                            <Label
                                x:Name="GenitiveCaseSubtitle"
                                FontSize="10"
                                Text="des, der, des"
                                TextColor="#777777" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    FontSize="15"
                    Text="Artikeltyp"
                    TextColor="#171717" />

                <Grid
                    ColumnDefinitions="*,*"
                    ColumnSpacing="8">
                    <Border
                        x:Name="DefiniteType"
                        Padding="10,8"
                        BackgroundColor="#EAF1FF"
                        Stroke="#2563EB"
                        StrokeThickness="2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDefiniteTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label
                                x:Name="DefiniteTypeTitle"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Text="Bestimmt"
                                TextColor="#2563EB" />
                            <Label
                                x:Name="DefiniteTypeSubtitle"
                                FontSize="10"
                                Text="der, die, das"
                                TextColor="#2563EB" />
                        </VerticalStackLayout>
                    </Border>

                    <Border
                        x:Name="IndefiniteType"
                        Grid.Column="1"
                        Padding="10,8"
                        BackgroundColor="#FFFFFF"
                        Stroke="#E4E4DE"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnIndefiniteTapped" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label
                                x:Name="IndefiniteTypeTitle"
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Text="Unbestimmt"
                                TextColor="#171717" />
                            <Label
                                x:Name="IndefiniteTypeSubtitle"
                                FontSize="10"
                                Text="ein, eine, ein"
                                TextColor="#777777" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Button
                    BackgroundColor="#D43D35"
                    Clicked="OnStartTestClicked"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    HeightRequest="48"
                    HorizontalOptions="Fill"
                    Text="Test starten"
                    TextColor="#FFFFFF" />

                <Button
                    x:Name="ReviewMistakesButton"
                    BackgroundColor="#FFFFFF"
                    BorderColor="#E4E4DE"
                    BorderWidth="1"
                    Clicked="OnReviewMistakesClicked"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    FontFamily="OpenSansSemibold"
                    HeightRequest="48"
                    HorizontalOptions="Fill"
                    Text="Fehler wiederholen"
                    TextColor="#171717" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

        <local:BottomNavigationView
            Grid.Row="1"
            SelectedTab="Practice"
            TabSelected="OnBottomTabSelected" />
    </Grid>

</ContentPage>
