<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GermanToolbox.VocabularyStartPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GermanToolbox"
    Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Offset="0.0" Color="#FAFAF8" />
            <GradientStop Offset="0.46" Color="#EEF4F8" />
            <GradientStop Offset="1.0" Color="#F3F7EF" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout
                Padding="20,18"
                Spacing="14">
                <Grid
                    ColumnDefinitions="40,*"
                    ColumnSpacing="10">
                    <Border
                        BackgroundColor="#FFFFFF"
                        HeightRequest="40"
                        Stroke="#E8E8E4"
                        StrokeThickness="1"
                        WidthRequest="40">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                        <Path
                            Aspect="Uniform"
                            Data="M 19 8 L 11 16 L 19 24"
                            Fill="Transparent"
                            HeightRequest="22"
                            HorizontalOptions="Center"
                            SemanticProperties.Description="Back"
                            Stroke="#171717"
                            StrokeLineCap="Round"
                            StrokeLineJoin="Round"
                            StrokeThickness="2.4"
                            VerticalOptions="Center"
                            WidthRequest="22" />
                    </Border>

                    <VerticalStackLayout
                        Grid.Column="1"
                        Spacing="0"
                        VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontFamily="OpenSansSemibold"
                            FontSize="22"
                            Text="Wortschatz"
                            TextColor="#171717" />
                            
                            <Grid
                                Margin="0,5,0,0"
                                ColumnDefinitions="16,16,16"
                                ColumnSpacing="5"
                                VerticalOptions="Center">
                                <BoxView
                                    BackgroundColor="#2563EB"
                                    CornerRadius="2"
                                    HeightRequest="4" />
                                <BoxView
                                    Grid.Column="1"
                                    BackgroundColor="#2E7D32"
                                    CornerRadius="2"
                                    HeightRequest="4" />
                                <BoxView
                                    Grid.Column="2"
                                    BackgroundColor="#F2C94C"
                                    CornerRadius="2"
                                    HeightRequest="4" />
                            </Grid>
                    </VerticalStackLayout>
                </Grid>

                <Border
                    Padding="16"
                    StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow
                            Brush="#30000000"
                            Offset="0,14"
                            Opacity="0.26"
                            Radius="24" />
                    </Border.Shadow>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0.0" Color="#182235" />
                            <GradientStop Offset="0.58" Color="#243B5A" />
                            <GradientStop Offset="1.0" Color="#141A25" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <VerticalStackLayout Spacing="12">

                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontAttributes="Bold"
                                FontFamily="OpenSansSemibold"
                                FontSize="30"
                                Text="Tippen, aufdecken, entscheiden"
                                TextColor="#FFFFFF" />
                            <Label
                                FontSize="13"
                                Text="Pick a level, flip each word for the translation, then keep what you know."
                                TextColor="#DCE8F6" />
                        </VerticalStackLayout>

                        <Grid
                            ColumnDefinitions="*,*,*"
                            ColumnSpacing="8">
                            <Border
                                Padding="9"
                                BackgroundColor="#18FFFFFF"
                                Stroke="#22FFFFFF"
                                StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="0">
                                    <Label
                                        FontSize="10"
                                        Text="Gelernt"
                                        TextColor="#C9D6E5" />
                                    <Label
                                        x:Name="VocabularyLearnedCountLabel"
                                        FontAttributes="Bold"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="18"
                                        Text="0"
                                        TextColor="#FFFFFF" />
                                </VerticalStackLayout>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="9"
                                BackgroundColor="#18FFFFFF"
                                Stroke="#22FFFFFF"
                                StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="0">
                                    <Label
                                        FontSize="10"
                                        Text="Gemeistert"
                                        TextColor="#C9D6E5" />
                                    <Label
                                        x:Name="VocabularyMasteredCountLabel"
                                        FontAttributes="Bold"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="18"
                                        Text="0"
                                        TextColor="#FFFFFF" />
                                </VerticalStackLayout>
                            </Border>

                            <Border
                                Grid.Column="2"
                                Padding="9"
                                BackgroundColor="#18FFFFFF"
                                Stroke="#22FFFFFF"
                                StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="0">
                                    <Label
                                        FontSize="10"
                                        Text="Fällig"
                                        TextColor="#C9D6E5" />
                                    <Label
                                        x:Name="VocabularyDueCountLabel"
                                        FontAttributes="Bold"
                                        FontFamily="OpenSansSemibold"
                                        FontSize="18"
                                        Text="18"
                                        TextColor="#FFFFFF" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="15"
                        Text="Niveau"
                        TextColor="#171717" />

                    <Grid
                        ColumnDefinitions="*,*,*,*,*"
                        ColumnSpacing="6">
                        <Border
                            x:Name="A1Level"
                            Padding="0"
                            BackgroundColor="#EAF1FF"
                            Stroke="#2563EB"
                            StrokeThickness="2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnA1Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="A1LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#D7E6FF"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="A1LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="A1"
                                    TextColor="#2563EB" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="A2Level"
                            Grid.Column="1"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="#E4E4DE"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnA2Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="A2LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#D7E6FF"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="A2LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="A2"
                                    TextColor="#171717" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="B1Level"
                            Grid.Column="2"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="#E4E4DE"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnB1Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="B1LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#D7E6FF"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="B1LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="B1"
                                    TextColor="#171717" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="B2Level"
                            Grid.Column="3"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="#E4E4DE"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnB2Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="B2LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#D7E6FF"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="B2LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="B2"
                                    TextColor="#171717" />
                            </Grid>
                        </Border>

                        <Border
                            x:Name="C1Level"
                            Grid.Column="4"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="#E4E4DE"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnC1Tapped" />
                            </Border.GestureRecognizers>
                            <Grid InputTransparent="True">
                                <AbsoluteLayout
                                    x:Name="C1LevelProgress"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                    <BoxView
                                        AbsoluteLayout.LayoutBounds="0,0,0,1"
                                        AbsoluteLayout.LayoutFlags="All"
                                        BackgroundColor="#D7E6FF"
                                        HorizontalOptions="Fill"
                                        VerticalOptions="Fill" />
                                </AbsoluteLayout>
                                <Label
                                    x:Name="C1LevelTitle"
                                    Margin="6,8"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="13"
                                    HorizontalTextAlignment="Center"
                                    Text="C1"
                                    TextColor="#171717" />
                            </Grid>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="6">
                    <Label
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="15"
                        Text="Richtung"
                        TextColor="#171717" />

                    <Grid
                        ColumnDefinitions="*,*"
                        ColumnSpacing="8">
                        <Border
                            x:Name="GermanToEnglishDirection"
                            Padding="12,10"
                            BackgroundColor="#EAF1FF"
                            Stroke="#2563EB"
                            StrokeThickness="2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnGermanToEnglishTapped" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3">
                                <Label
                                    x:Name="GermanToEnglishDirectionTitle"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="14"
                                    Text="DE &#x2192; EN"
                                    TextColor="#2563EB" />
                                <Label
                                    x:Name="GermanToEnglishDirectionSubtitle"
                                    FontSize="11"
                                    Text="Reveal translation"
                                    TextColor="#2563EB" />
                            </VerticalStackLayout>
                        </Border>

                        <Border
                            x:Name="EnglishToGermanDirection"
                            Grid.Column="1"
                            Padding="12,10"
                            BackgroundColor="#FFFFFF"
                            Stroke="#E4E4DE"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnEnglishToGermanTapped" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="3">
                                <Label
                                    x:Name="EnglishToGermanDirectionTitle"
                                    FontAttributes="Bold"
                                    FontFamily="OpenSansSemibold"
                                    FontSize="14"
                                    Text="EN &#x2192; DE"
                                    TextColor="#171717" />
                                <Label
                                    x:Name="EnglishToGermanDirectionSubtitle"
                                    FontSize="11"
                                    Text="Reveal German word"
                                    TextColor="#777777" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Button
                        BackgroundColor="#2563EB"
                        Clicked="OnStartTestClicked"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        HeightRequest="48"
                        HorizontalOptions="Fill"
                        Text="Test starten"
                        TextColor="#FFFFFF" />

                    <Button
                        x:Name="ReviewWordsButton"
                        BackgroundColor="#FFFFFF"
                        BorderColor="#DDE8F5"
                        BorderWidth="1"
                        Clicked="OnReviewWordsClicked"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        HeightRequest="48"
                        HorizontalOptions="Fill"
                        Text="Wörter wiederholen"
                        TextColor="#171717" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <local:BottomNavigationView
            Grid.Row="1"
            SelectedTab="Practice"
            TabSelected="OnBottomTabSelected" />
    </Grid>

</ContentPage>
