<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="GermanToolbox.BottomNavigationView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        Margin="24,8,24,10"
        Padding="4"
        BackgroundColor="#FFFFFF"
        Stroke="#E8E8E4"
        StrokeThickness="1">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="8" />
        </Border.StrokeShape>
        <Border.Shadow>
            <Shadow
                Brush="#22000000"
                Offset="0,6"
                Opacity="0.2"
                Radius="14" />
        </Border.Shadow>

        <Grid
            ColumnDefinitions="*,*,*,*"
            ColumnSpacing="4"
            HeightRequest="50">
            <Border
                x:Name="HomeTabBackground"
                BackgroundColor="#EAF1FF"
                StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnHomeTapped" />
                </Border.GestureRecognizers>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid
                    Padding="0,3"
                    RowDefinitions="21,Auto"
                    RowSpacing="1"
                    VerticalOptions="Center">
                    <Path
                        x:Name="HomeIcon"
                        Aspect="Uniform"
                        Data="M 16 9.226 L 8 3.016 L 0 9.226 V 6.694 L 8 0.484 L 16 6.694 Z M 14 9 V 15 H 10 V 11 H 6 V 15 H 2 V 9 L 8 4.5 Z"
                        Fill="Transparent"
                        HeightRequest="21"
                        HorizontalOptions="Center"
                        SemanticProperties.Description="Home"
                        Stroke="#2563EB"
                        StrokeLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeThickness="1.4"
                        VerticalOptions="Center"
                        WidthRequest="21" />
                    <Label
                        x:Name="HomeLabel"
                        Grid.Row="1"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="9"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="NoWrap"
                        Text="Start"
                        TextColor="#2563EB"
                        VerticalTextAlignment="Center" />
                </Grid>
            </Border>

            <Border
                x:Name="PracticeTabBackground"
                Grid.Column="1"
                BackgroundColor="Transparent"
                StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPracticeTapped" />
                </Border.GestureRecognizers>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid
                    Padding="0,3"
                    RowDefinitions="21,Auto"
                    RowSpacing="1"
                    VerticalOptions="Center">
                    <Path
                        x:Name="PracticeIcon"
                        Aspect="Uniform"
                        Data="M 8 6 H 24 C 25.1 6 26 6.9 26 8 V 24 C 26 25.1 25.1 26 24 26 H 8 C 6.9 26 6 25.1 6 24 V 8 C 6 6.9 6.9 6 8 6 Z M 10.5 12 H 21.5 M 10.5 17 H 19"
                        Fill="Transparent"
                        HeightRequest="21"
                        HorizontalOptions="Center"
                        SemanticProperties.Description="Practice"
                        Stroke="#777777"
                        StrokeLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeThickness="2.1"
                        VerticalOptions="Center"
                        WidthRequest="21" />
                    <Label
                        x:Name="PracticeLabel"
                        Grid.Row="1"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="9"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="NoWrap"
                        Text="Üben"
                        TextColor="#777777"
                        VerticalTextAlignment="Center" />
                </Grid>
            </Border>

            <Border
                x:Name="SearchTabBackground"
                Grid.Column="2"
                BackgroundColor="Transparent"
                StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSearchTapped" />
                </Border.GestureRecognizers>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid
                    Padding="0,3"
                    RowDefinitions="21,Auto"
                    RowSpacing="1"
                    VerticalOptions="Center">
                    <Path
                        x:Name="SearchIcon"
                        Aspect="Uniform"
                        Data="M 13 4 A 9 9 0 1 0 13 22 A 9 9 0 1 0 13 4 M 20 20 L 27 27"
                        Fill="Transparent"
                        HeightRequest="21"
                        HorizontalOptions="Center"
                        SemanticProperties.Description="Search"
                        Stroke="#777777"
                        StrokeLineCap="Round"
                        StrokeThickness="2.1"
                        VerticalOptions="Center"
                        WidthRequest="21" />
                    <Label
                        x:Name="SearchLabel"
                        Grid.Row="1"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="9"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="NoWrap"
                        Text="Suche"
                        TextColor="#777777"
                        VerticalTextAlignment="Center" />
                </Grid>
            </Border>

            <Border
                x:Name="SettingsTabBackground"
                Grid.Column="3"
                BackgroundColor="Transparent"
                StrokeThickness="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSettingsTapped" />
                </Border.GestureRecognizers>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Grid
                    Padding="0,3"
                    RowDefinitions="21,Auto"
                    RowSpacing="1"
                    VerticalOptions="Center">
                    <Path
                        x:Name="SettingsIcon"
                        Aspect="Uniform"
                        Data="M 15.5 12 A 3.5 3.5 0 1 1 8.5 12 A 3.5 3.5 0 1 1 15.5 12 M 20.79 9.152 C 21.598 10.542 22 11.237 22 12 C 22 12.763 21.597 13.458 20.79 14.848 L 18.867 18.164 C 18.064 19.548 17.662 20.24 17.002 20.62 C 16.342 21 15.54 21 13.937 21 H 10.063 C 8.46 21 7.658 21 6.998 20.62 C 6.338 20.24 5.936 19.548 5.133 18.164 L 3.21 14.848 C 2.403 13.458 2 12.763 2 12 C 2 11.237 2.403 10.542 3.21 9.152 L 5.133 5.836 C 5.936 4.452 6.338 3.76 6.998 3.38 C 7.658 3 8.46 3 10.063 3 H 13.937 C 15.54 3 16.342 3 17.002 3.38 C 17.662 3.76 18.064 4.452 18.867 5.836 Z"
                        Fill="Transparent"
                        HeightRequest="21"
                        HorizontalOptions="Center"
                        SemanticProperties.Description="Settings"
                        Stroke="#777777"
                        StrokeLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeThickness="1.5"
                        VerticalOptions="Center"
                        WidthRequest="21" />
                    <Label
                        x:Name="SettingsLabel"
                        Grid.Row="1"
                        FontAttributes="Bold"
                        FontFamily="OpenSansSemibold"
                        FontSize="9"
                        HorizontalTextAlignment="Center"
                        LineBreakMode="NoWrap"
                        Text="Einstellungen"
                        TextColor="#777777"
                        VerticalTextAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Border>

</ContentView>
